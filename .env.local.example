VITE_TICKETING_SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
VITE_TICKETING_SUPABASE_ANON_KEY=YOUR_STANDALONE_SUPABASE_ANON_KEY
VITE_TICKET_AI_SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
VITE_TICKET_AI_SUPABASE_ANON_KEY=YOUR_STANDALONE_SUPABASE_ANON_KEY
VITE_MOMENCE_FUNCTION_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co/functions/v1/momence-search
VITE_MOMENCE_FUNCTION_ANON_KEY=YOUR_STANDALONE_SUPABASE_ANON_KEY
# Optional: use only if supabase/functions/momence-session-search is deployed.
VITE_MOMENCE_SESSION_FUNCTION_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co/functions/v1/momence-session-search
VITE_MOMENCE_SESSION_FUNCTION_ANON_KEY=YOUR_STANDALONE_SUPABASE_ANON_KEY

# Frontend provider switch. Server-side Supabase function secrets still need the matching API key.
VITE_AI_PROVIDER=openai

# Supabase function secrets:
# AI_PROVIDER=openai
# DEEPSEEK_API_KEY=...
# DEEPSEEK_MODEL=deepseek-v4-pro
# OPENAI_API_KEY=...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
